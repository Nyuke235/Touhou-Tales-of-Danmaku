{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Touhou - Tales of Danmaku",
	"version": "1.0.0",
	"identifier": "com.nyuke235.tales-of-danmaku",
	"build": {
		"beforeDevCommand": "npm run start",
		"devUrl": "http://localhost:8000",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Touhou - Tales of Danmaku",
				"width": 1200,
				"height": 900,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"center": true,
				"zoomHotkeysEnabled": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": ["../assets/audio/**/*"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"linux": {
			"deb": {
				"depends": [
					"libwebkit2gtk-4.1-0",
					"libgtk-3-0",
					"libgstreamer1.0-0",
					"gstreamer1.0-plugins-base",
					"gstreamer1.0-plugins-good",
					"libasound2"
				]
			}
		}
	}
}
